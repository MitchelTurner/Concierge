TELEGRAM_BOT_TOKEN=        # from @BotFather
DATABASE_URL=              # PostgreSQL connection string (Railway Postgres sets this automatically)
DATABASE_SSL=              # set to "false" for local Postgres without SSL; Railway: leave unset
DAILY_TIME=07:30           # default daily nudge time for new accounts (24h HH:MM)
CHECKIN_TIME=20:00         # default evening check-in for new accounts (24h HH:MM)
STALL_DAYS=4               # default stall threshold for new accounts
TZ=America/Chicago         # default timezone for new accounts
ANTHROPIC_API_KEY=         # enables the AI assistant (dashboard + Telegram chat); leave blank to disable
ANTHROPIC_MODEL=claude-sonnet-4-6   # model for the AI agent (override if needed)
OPENAI_API_KEY=            # enables Telegram voice-note transcription; leave blank to disable
OPENAI_TRANSCRIBE_MODEL=whisper-1   # transcription model (override if needed)
SMTP_HOST=                 # enables sending client outreach emails (e.g. smtp.gmail.com)
SMTP_PORT=587              # 465 = implicit TLS, 587 = STARTTLS
SMTP_USER=                 # SMTP login (often your email address)
SMTP_PASS=                 # SMTP password / app password
SMTP_FROM=                 # From address, e.g. "Alex <alex@example.com>" (defaults to SMTP_USER)
IMAP_HOST=                 # enables client reply detection (e.g. imap.gmail.com)
IMAP_PORT=993              # IMAP port (993 = TLS)
IMAP_USER=                 # IMAP login (defaults to SMTP_USER)
IMAP_PASS=                 # IMAP password (defaults to SMTP_PASS)
SEED_DEMO_DATA=            # local default: demo rows on new signup. Railway: never (set true to force)
PORT=3000                  # web dashboard port (Railway sets this automatically)
